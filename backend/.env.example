# ---- BasketIQ backend env (copy to .env, never commit .env) ----

# Supabase — Project Settings > API
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Use the service_role key on the server ONLY (full access, bypasses RLS).
# Never ship this key to the mobile app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Gemini via Vertex AI (service-account auth, GCP billing) ----
# Path to the service-account JSON. Relative paths resolve from backend/.
GOOGLE_APPLICATION_CREDENTIALS=./sa-vertex.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# CORS — comma-separated origins allowed to call this API (Expo dev, etc.)
# "*" is fine for local dev only.
ALLOWED_ORIGINS=*
