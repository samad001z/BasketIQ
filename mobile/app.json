{
  "expo": {
    "name": "BasketIQ",
    "slug": "basketiq",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "basketiq",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.basketiq.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16A34A"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.basketiq.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#16A34A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30fe43db-da8e-4269-aaa1-b1df01a8f2fc"
      }
    },
    "owner": "samad001zs-team"
  }
}
