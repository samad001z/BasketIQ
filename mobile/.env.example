# ---- BasketIQ mobile env (copy to .env, never commit .env) ----
# Only EXPO_PUBLIC_* vars are exposed to the app bundle. Never put secrets
# (Supabase service role, Gemini key) here — those live in the backend.

# Base URL of the FastAPI backend.
#  - Android emulator  -> http://10.0.2.2:8000
#  - USB device        -> http://localhost:8000  (with: adb reverse tcp:8000 tcp:8000)
#  - Physical (Wi-Fi)  -> http://<your-LAN-IP>:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Supabase — for AUTH + REALTIME only (the one allowed direct mobile↔Supabase
# path). Use the PUBLISHABLE/ANON key, never the service_role.
# From Supabase dashboard → Project Settings → API.
# Leave blank to run as a guest (no login / no live price toasts).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
